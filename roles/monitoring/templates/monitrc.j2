# Managed by Ansible — 手動編集禁止
# F23 (SES SMTP), F12 (check program for log-ship health)

set daemon 60
set log syslog
set pidfile /run/monit.pid
set statefile /var/lib/monit/state
set httpd port 2812 and
  use address localhost
  allow localhost

set alert {{ ses_alert_recipient }}

# F23: AWS SES SMTP relay (postfix 経由ではなく monit が直接 SES に送信)
# postfix も並行稼働するが、monit のアラートは独立した経路にして
# postfix 自体が壊れた時も検知できるようにする
set mailserver {{ ses_smtp_host }} port {{ ses_smtp_port }}
  username "{{ vault.ses_smtp_username }}" password "{{ vault.ses_smtp_password }}"
  using tlsv12

set mail-format {
  from: {{ ses_from_address }}
  subject: "[codens-vps] $HOST: $SERVICE $EVENT"
}

# ===== System =====
check system $HOST
  if cpu usage > 90% for 5 cycles then alert
  if memory usage > 85% then alert
  if loadavg (5min) > 8 then alert

check filesystem root with path /
  if space usage > 85% then alert
  if inode usage > 85% then alert

# ===== Critical processes =====
check process cloudflared matching "cloudflared"
  start program = "/bin/systemctl start cloudflared"
  stop program  = "/bin/systemctl stop cloudflared"
  if not exist for 3 cycles then alert
  if 5 restarts within 15 cycles then alert

check process code-server matching "code-server"
  start program = "/bin/systemctl start code-server"
  stop program  = "/bin/systemctl stop code-server"
  if not exist for 3 cycles then alert

check process sshd matching "sshd:"
  if not exist then alert

check process postfix matching "qmgr"
  start program = "/bin/systemctl start postfix"
  if not exist for 3 cycles then alert

# ===== F12: log-ship health check (check program 方式) =====
check program codens-log-ship-health with path "/usr/local/bin/codens-log-ship-health"
  every 10 cycles
  if status != 0 then alert

# F12: prom file が 2h 以上更新なし → cron 自体が動いていない
check file log-ship-metrics with path /var/lib/node_exporter/textfile_collector/codens_log_ship.prom
  if timestamp > 2 hours then alert
