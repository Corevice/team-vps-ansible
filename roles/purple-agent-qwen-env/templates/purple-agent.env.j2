# /etc/purple-agent.env — managed by ansible role purple-agent-qwen-env
# Source: plans/team-vps-setup/roles/purple-agent-qwen-env/templates/purple-agent.env.j2
#
# Environment for purple-agent.service (purple-codens VPS-side agent).
# When the service is deployed and starts, these variables enable Qwen gateway
# routing for jobs with claude_model="qwen". Without these, the agent falls
# back to Anthropic OAuth (= Qwen routing disabled).
#
# This file is pre-staged on every VPS so that when purple-codens deploys the
# agent service to a node, Qwen routing works out of the box.

# Self-hosted Qwen gateway via Cloudflare Tunnel (CF Zero Trust private route)
CLAUDE_QWEN_GATEWAY_URL=https://qwen-gw.vps.example.com

# Per-VPS gateway key — counted as owner=$OWNER in nginx audit log + subject
# to per-owner limit_conn=4. Same key the interactive claude-qwen on this VPS
# uses, so agent + interactive share one owner identity (correct semantics:
# "$OWNER's qwen usage" includes both).
CLAUDE_QWEN_GATEWAY_TOKEN={{ qwen_vps_keys[owner] }}

# Optional: gateway model identifier (CCR routes by name prefix). The default
# below matches what claude-qwen.sh uses; production CCR config serves both
# Qwen and the legacy GLM name so either resolves to the same backend.
CLAUDE_QWEN_MODEL=vllm-qwen,Qwen/Qwen3.6-27B-FP8
